{
  "name": "cd-dashboard-test",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:static": "VITE_DATA_MODE=static sh -c 'vue-tsc -b && vite build'",
    "preview": "vite preview",
    "export:static-data": "bash scripts/export-static-data.sh",
    "publish:static": "bash scripts/publish-static-site.sh",
    "test": "vitest run",
    "lint": "eslint . --ext .js,.cjs,.ts,.vue",
    "lint:fix": "eslint . --ext .js,.cjs,.ts,.vue --fix",
    "runstatic": "npm run export:static-data && npm run build:static && python3 -m http.server 4173 -d dist"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.60.0",
    "apexcharts": "^5.10.5",
    "axios": "^1.15.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue3-apexcharts": "^1.11.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.0.0",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.30.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.5.9",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.6"
  }
}
