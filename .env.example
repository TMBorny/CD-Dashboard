# Client Health Dashboard — environment configuration
#
# Copy this file to .env and fill in your values.
# Run `bash scripts/setup-dev.sh` to do this automatically.
#
# This is the ONLY .env file needed — both the frontend (Vite) and
# the backend (FastAPI) read from this single file.

# ----- Internal API Key -------------------------------------------------------
# Shared secret between Vite and the FastAPI backend.
# Generated automatically by setup-dev.sh — you can also set it manually.
VITE_INTERNAL_API_KEY=replace-with-a-long-random-string

# ----- Coursedog Credentials --------------------------------------------------
# Required for live syncs and backfills.
VITE_COURSEDOG_PRD_URL=https://app.coursedog.com
VITE_COURSEDOG_EMAIL=your-email@example.com
VITE_COURSEDOG_PASSWORD=replace-me

# ----- Dev Server -------------------------------------------------------------
# URL the Vite proxy forwards /backend/* requests to.
BACKEND_URL=http://localhost:8000

# ----- CORS -------------------------------------------------------------------
# Comma-separated origins the backend will accept requests from.
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
